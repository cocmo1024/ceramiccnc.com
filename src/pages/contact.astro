---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import { createBreadcrumbSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const contactShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/copper/rfq-review-workspace.webp',
      alt: 'Copper AM RFQ email review workspace',
    },
    title: 'What to include',
    description:
      'A short email is fine if the project is simple. Add only the details that affect quotation and acceptance.',
    points: [
      {
        title: 'Drawings and CAD',
        description: 'Attach STEP, X_T, native CAD, or drawings with key dimensions and critical surfaces.',
      },
      {
        title: 'Quantity and timing',
        description: 'State prototype quantity, batch quantity, target delivery date, and any purchasing constraints.',
      },
      {
        title: 'Requirements',
        description:
          'Include material, pressure, leak, thermal, electrical, surface finish, machining, CT, or cleaning needs when relevant.',
      },
    ],
  },
  {
    imagePosition: 'right' as const,
    image: {
      src: '~/assets/images/copper/hero-2.webp',
      alt: 'Copper additive manufacturing parts for RFQ review',
    },
    title: 'How we respond',
    description:
      'The reply depends on the drawing and the requirements. We do not force every RFQ into the same deliverable.',
    points: [
      {
        title: 'Simple quote',
        description:
          'If geometry, quantity, and basic requirements are clear, we can respond with a straightforward quotation.',
      },
      {
        title: 'Clarification questions',
        description:
          'If heat load, pressure, current, leak target, drawings, or inspection needs are unclear, we ask focused questions before quoting.',
      },
      {
        title: 'Technical discussion when needed',
        description:
          'For complex parts, we may discuss material, manufacturability, post-processing, testing, and lead-time drivers as needed.',
      },
    ],
  },
];

const metadata = {
  title: 'Copper AM RFQ Contact | Send CAD for Quote',
  description:
    'Email copper 3D printing RFQ details with drawings, quantity, material target, lead time, operating constraints, and inspection requirements.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/copper/hero-1.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: createBreadcrumbSchema([
    { name: 'Home', item: '/' },
    { name: 'Contact', item: '/contact' },
  ]),
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Project RFQ"
    title="Email your drawing, quantity, and requirements"
    subtitle="We quote copper 3D printing projects from the information you send. If the drawing and requirements are clear, we quote; if key details are unclear, we ask before quoting."
  />

  <CallToAction
    id="form"
    classes={{ container: sectionContainerClass }}
    title="Send the RFQ by email"
    subtitle="Email STEP, X_T, native CAD, drawings, quantity, material if known, lead time, and the requirements that matter for the part."
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: 'mailto:info@szcomo.com',
        icon: 'tabler:mail',
      },
      {
        text: 'Review RFQ inputs',
        href: '/rfq',
      },
    ]}
  />

  <SplitShowcase
    title="Email-first RFQ path"
    subtitle="Send the drawing and what you know. Leave unknown fields blank rather than guessing."
    items={contactShowcases}
    classes={{ container: sectionContainerClass }}
  />
</Layout>
