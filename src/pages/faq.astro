---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { ceramicFaqItems, rfqEmailHref } from '~/data/ceramic';
import { createBreadcrumbSchema, createFAQPageSchema } from '~/utils/structured-data';

const metadata = {
  title: 'Ceramic CNC Machining FAQ',
  description:
    'FAQ for precision ceramic CNC machining, diamond grinding, lapping, tolerances, Ra, micro-holes, material selection, inspection planning, and RFQ inputs.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'FAQ', item: '/faq/' },
    ]),
    createFAQPageSchema(ceramicFaqItems),
  ],
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="FAQ"
    title="Precision ceramic CNC machining FAQ"
    subtitle="Answers for ceramic RFQ preparation, material choice, green vs hard machining, tolerances, surface finish, micro-holes, inspection, and acceptance criteria."
  />

  <FAQs
    title="RFQ and engineering questions"
    subtitle="Use these answers to reduce ambiguity before sending a drawing for quotation."
    columns={1}
    items={ceramicFaqItems}
  />

  <CallToAction
    title="Ready to send a ceramic RFQ?"
    subtitle="Send drawings, material, quantity, target lead time, and acceptance requirements. After review, we respond with feasibility notes, questions, or quotation details."
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: rfqEmailHref,
        icon: 'tabler:mail',
      },
      {
        text: 'RFQ checklist',
        href: '/rfq/',
      },
    ]}
  />
</Layout>
