---
const target = '/rfq/';
const title = 'RFQ Checklist | COPPER 3DP';
const description = 'The former FAQ page has moved to the RFQ checklist for copper 3D printing inquiries.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href="https://copper3dp.com/rfq/" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main>
      <h1>RFQ checklist</h1>
      <p>The FAQ page has moved. Continue to the <a href={target}>RFQ checklist</a>.</p>
    </main>
  </body>
</html>
