---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { ceramicMaterials, rfqEmailHref } from '~/data/ceramic';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const materialShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/ceramic/application-5.webp',
      alt: 'SiC and Si3N4 ceramic wear parts material selection',
    },
    title: 'Select material by failure mode, not by name alone',
    description:
      'A ceramic grade should be chosen against the real constraint: wear, chipping, thermal shock, dielectric performance, vacuum, chemical exposure, or machinability.',
    points: [
      {
        title: 'Mechanical risk',
        description:
          'Impact, tensile stress, unsupported thin walls, and sharp transitions can make a high-hardness ceramic fail early.',
      },
      {
        title: 'Thermal and chemical environment',
        description:
          'Temperature profile, ramp rate, atmosphere, media chemistry, and erosion condition affect both material and design choices.',
      },
      {
        title: 'Finishability',
        description:
          'A material that is excellent in service may be expensive to grind or polish to tight Ra and tolerance targets.',
      },
    ],
  },
  {
    imagePosition: 'right' as const,
    image: {
      src: '~/assets/images/ceramic/application-4.webp',
      alt: 'Alumina ceramic insulator material selection',
    },
    title: 'Lock grade and acceptance before production',
    description:
      'Two parts called alumina or zirconia can behave differently. Purity, density, grain size, sintering aids, and supplier grade can affect strength, wear, insulation, and finishing behavior.',
    points: [
      {
        title: 'Grade definition',
        description:
          'Specify grade or minimum property targets when density, porosity, insulation, wear, or vacuum behavior is function-critical.',
      },
      {
        title: 'Functional faces',
        description:
          'Tie tight tolerances and low Ra to the faces that actually seal, locate, insulate, guide, or wear.',
      },
      {
        title: 'Evidence',
        description:
          'Request material certificate, CoC, density or porosity evidence, and dimensional reports when the application needs traceability.',
      },
    ],
  },
];

const metadata = {
  title: 'Advanced Ceramic Materials for CNC Machining',
  description:
    'Material selection for precision ceramic CNC machining: alumina Al2O3, zirconia ZrO2, silicon nitride Si3N4, silicon carbide SiC, MACOR, AlN, BN, fused silica, density, hardness, dielectric, thermal, and wear considerations.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/application-5.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Materials', item: '/materials' },
    ]),
    createItemListSchema(
      'Advanced ceramic materials for CNC machining',
      ceramicMaterials.map((item) => ({
        name: item.title,
        description: item.description,
        url: '/materials',
      }))
    ),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Materials"
    title="Advanced ceramic materials for precision machining"
    subtitle="If you know the ceramic grade, send it. If not, send the operating environment, failure mode, tolerance targets, and inspection needs so a material route can be reviewed."
    actions={[
      {
        variant: 'primary',
        text: 'Email material review',
        href: rfqEmailHref,
      },
      { text: 'RFQ inputs', href: '/rfq' },
    ]}
    image={{
      src: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
      alt: 'Advanced ceramic materials for CNC machining review',
      class: 'mx-auto w-full',
    }}
  />

  <Features2
    title="Common material paths"
    subtitle="The right ceramic route is selected against the function of the part, not by material name alone."
    columns={3}
    items={ceramicMaterials}
  />

  <SplitShowcase items={materialShowcases} classes={{ container: sectionContainerClass }} />

  <section class:list={['relative not-prose', sectionContainerClass]}>
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div
        class="overflow-hidden rounded-md border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900"
      >
        <div class="px-5 py-4 md:px-6">
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">Procurement note</p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight dark:text-white">
            Generic material labels are not enough for critical ceramic parts.
          </h2>
          <p class="mt-3 text-muted dark:text-slate-300">
            For sealing, vacuum, wear, high-voltage, thermal cycling, and semiconductor applications, specify grade,
            density or porosity expectations, critical faces, edge condition, and required evidence before quoting.
          </p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200 text-sm dark:divide-slate-700">
            <thead class="bg-slate-50 text-left text-slate-700 dark:bg-slate-800 dark:text-slate-200">
              <tr>
                <th class="px-5 py-3 font-semibold">Material</th>
                <th class="px-5 py-3 font-semibold">Common reason to choose</th>
                <th class="px-5 py-3 font-semibold">RFQ caution</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
              <tr>
                <td class="px-5 py-3 font-medium">Al2O3</td>
                <td class="px-5 py-3">Insulation, wear resistance, chemical stability, cost efficiency.</td>
                <td class="px-5 py-3">Specify purity, density, surface finish, and finished faces.</td>
              </tr>
              <tr>
                <td class="px-5 py-3 font-medium">ZrO2</td>
                <td class="px-5 py-3">Higher toughness and reduced chipping risk for selected mechanical parts.</td>
                <td class="px-5 py-3">Control thermal environment, dimensional stability, and mating faces.</td>
              </tr>
              <tr>
                <td class="px-5 py-3 font-medium">Si3N4</td>
                <td class="px-5 py-3">Bearings, wear parts, and thermally shocked mechanical components.</td>
                <td class="px-5 py-3">Define load mode, edge quality, roundness, and inspection method.</td>
              </tr>
              <tr>
                <td class="px-5 py-3 font-medium">SiC</td>
                <td class="px-5 py-3">Extreme wear, chemical resistance, seals, nozzles, and harsh process hardware.</td
                >
                <td class="px-5 py-3">Very hard to finish; localize tight tolerances and low Ra.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    classes={{ container: sectionContainerClass }}
    title="Not sure which ceramic material fits the part?"
    subtitle="Send the CAD package, quantity, operating environment, failure mode, and critical requirements so the material route can be reviewed."
    actions={[
      {
        variant: 'primary',
        text: 'Email drawing for review',
        href: rfqEmailHref,
      },
    ]}
  />
</Layout>
