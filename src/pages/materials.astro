---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { ceramicMaterials, rfqEmailHref } from '~/data/ceramic';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const materialShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/ceramic/application-5.webp',
      alt: 'SiC and Si3N4 ceramic wear parts material selection',
    },
    title: 'Select material by failure mode, not by name alone',
    description:
      'A ceramic grade should be chosen against the real constraint: wear, chipping, thermal shock, dielectric performance, vacuum, chemical exposure, machinability, and available blank form.',
    points: [
      {
        title: 'Mechanical risk',
        description:
          'Impact, tensile stress, unsupported thin walls, and sharp transitions can make a high-hardness ceramic fail early.',
      },
      {
        title: 'Thermal and chemical environment',
        description:
          'Temperature profile, ramp rate, atmosphere, media chemistry, and erosion condition affect both material and design choices.',
      },
      {
        title: 'Finishability',
        description:
          'A material that is excellent in service may be expensive to grind or polish to tight Ra and tolerance targets.',
      },
    ],
  },
];

const materialGuideLinks = [
  {
    title: 'Material selection hub',
    description:
      'Compare ceramic families by failure mode, blank state, feature risk, finishability, and RFQ evidence.',
    icon: 'tabler:route',
    callToAction: {
      text: 'Read selection guide',
      href: '/posts/materials-grade-selection/ceramic-material-selection-cnc-machining/',
    },
  },
  {
    title: 'Alumina ceramic machining',
    description:
      'Review alumina insulators, bushings, plates, spacers, sleeves, fixtures, purity notes, and finished faces.',
    icon: 'tabler:hexagon-letter-a',
    callToAction: {
      text: 'Read alumina guide',
      href: '/posts/industrial-ceramic-machining/precision-machined-alumina-ceramic-parts-industrial-applications/',
    },
  },
  {
    title: 'Zirconia ceramic machining',
    description:
      'Review zirconia pins, plungers, bushings, sleeves, wear parts, toughness limits, tolerances, and surface finish.',
    icon: 'tabler:hexagon-letter-z',
    callToAction: {
      text: 'Read zirconia guide',
      href: '/posts/industrial-ceramic-machining/zirconia-ceramic-machining-high-strength-precision-components/',
    },
  },
  {
    title: 'Silicon nitride ceramic machining',
    description:
      'Review Si3N4 rollers, shafts, sleeves, guide parts, thermal shock exposure, roundness, and inspection needs.',
    icon: 'tabler:hexagon-letter-s',
    callToAction: {
      text: 'Read Si3N4 guide',
      href: '/posts/industrial-ceramic-machining/silicon-nitride-ceramic-machining-structural-wear-parts/',
    },
  },
  {
    title: 'Silicon carbide ceramic machining',
    description:
      'Review SiC seal faces, valve seats, pump sleeves, nozzles, wear plates, semiconductor parts, and lapped faces.',
    icon: 'tabler:shield-check',
    callToAction: {
      text: 'Read SiC guide',
      href: '/posts/industrial-ceramic-machining/silicon-carbide-ceramic-machining-harsh-environment-applications/',
    },
  },
  {
    title: 'Aluminum nitride ceramic machining',
    description:
      'Review AlN heat spreaders, insulating plates, thermal-interface flatness, cleanliness, and power electronics use.',
    icon: 'tabler:temperature',
    callToAction: {
      text: 'Read AlN guide',
      href: '/posts/industrial-ceramic-machining/aluminum-nitride-ceramic-machining-thermal-management-components/',
    },
  },
  {
    title: 'Macor machinable ceramic parts',
    description:
      'Review Macor prototype parts, lab fixtures, insulating hardware, threads, fast iteration, and production limits.',
    icon: 'tabler:tool',
    callToAction: {
      text: 'Read Macor guide',
      href: '/posts/industrial-ceramic-machining/macor-machinable-glass-ceramic-parts-applications-design-guide/',
    },
  },
  {
    title: 'Boron nitride ceramic machining',
    description:
      'Review BN high-temperature insulation parts, furnace fixtures, molten-metal-adjacent nozzles, spacers, and tubes.',
    icon: 'tabler:flame',
    callToAction: {
      text: 'Read BN guide',
      href: '/posts/industrial-ceramic-machining/boron-nitride-ceramic-machining-high-temperature-insulation-parts/',
    },
  },
  {
    title: 'Precision ceramic machining overview',
    description:
      'Use the process overview when material choice, grinding route, tolerances, surface finish, and inspection overlap.',
    icon: 'tabler:settings',
    callToAction: {
      text: 'Read overview',
      href: '/posts/industrial-ceramic-machining/precision-ceramic-machining-high-performance-industrial-components/',
    },
  },
];

const metadata = {
  title: 'Advanced Ceramic Materials for CNC Machining',
  description:
    'CNC machining material guide for alumina, zirconia, silicon nitride, silicon carbide, MACOR, AlN, BN, fused silica, and advanced ceramic grades.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/application-5.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Materials', item: '/materials/' },
    ]),
    createItemListSchema(
      'Advanced ceramic materials for CNC machining',
      ceramicMaterials.map((item) => ({
        name: item.title,
        description: item.description,
        url: '/materials/',
      }))
    ),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Materials"
    title="Advanced ceramic materials for precision machining"
    subtitle="If you know the ceramic grade and blank source, send them. If not, send the operating environment, failure mode, tolerance targets, and inspection needs so a material route can be reviewed."
    actions={[
      {
        variant: 'primary',
        text: 'Email material review',
        href: rfqEmailHref,
      },
      { text: 'RFQ inputs', href: '/rfq/' },
    ]}
    image={{
      src: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
      alt: 'Advanced ceramic materials for CNC machining review',
      class: 'mx-auto w-full',
    }}
  />

  <Features2
    title="Common material paths"
    subtitle="The right ceramic route is selected against the function of the part, not by material name alone."
    columns={3}
    items={ceramicMaterials}
  />

  <SplitShowcase items={materialShowcases} classes={{ container: sectionContainerClass }} />

  <Features2
    title="Material machining guides"
    subtitle="Use these pages as the internal route from material name to machining risk, application fit, tolerance scope, surface finish, and RFQ inputs."
    columns={3}
    items={materialGuideLinks}
    classes={{ container: sectionContainerClass }}
  />

  <CallToAction
    classes={{ container: sectionContainerClass }}
    title="Not sure which ceramic material fits the part?"
    subtitle="Send the CAD package, quantity, available blank information, operating environment, failure mode, and critical requirements so the material route can be reviewed."
    actions={[
      {
        variant: 'primary',
        text: 'Email drawing for review',
        href: rfqEmailHref,
      },
    ]}
  />
</Layout>
