---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const materialShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/copper/induction-heating-coils.webp',
      alt: 'Copper induction coil material review',
    },
    title: 'Material decision inputs that speed review',
    description:
      'The same alloy can behave differently depending on wall thickness, heat treatment, machining allowance, inspection scope, and operating environment.',
    points: [
      {
        title: 'Conductivity after processing',
        description:
          'Conductivity targets should be discussed after stress relief, heat treatment, machining, polishing, or plating requirements are known.',
      },
      {
        title: 'Strength and service temperature',
        description:
          'Clamp loads, pressure loads, thermal cycling, and local wall thickness determine whether pure copper is enough.',
      },
      {
        title: 'Inspection and certification',
        description:
          'State whether material certificates, density expectations, CT review, or leak-test requirements are needed.',
      },
    ],
  },
];

const metadata = {
  title: 'Copper AM Materials | Pure Copper & CuCrZr',
  description:
    'Material selection for LPBF copper AM: pure copper, CuCrZr, and GRCop-42 for thermal, electrical, aerospace, and high-temperature parts.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/copper/high-current-busbars.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Materials', item: '/materials' },
    ]),
    createItemListSchema('Copper AM material paths', [
      {
        name: 'Pure copper',
        description: 'Reviewed when electrical or thermal conductivity is the dominant requirement.',
        url: '/materials',
      },
      {
        name: 'CuCrZr',
        description: 'Reviewed when strength and softening resistance matter alongside conductivity.',
        url: '/materials',
      },
      {
        name: 'GRCop-42',
        description:
          'Reviewed for high-temperature aerospace and thermal hardware where qualification documentation matters.',
        url: '/materials',
      },
    ]),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Materials"
    title="Copper material options for 3D printing"
    subtitle="If you know the material, send it. If not, send operating requirements so we can discuss pure copper, CuCrZr, or GRCop-42 as needed."
    actions={[
      {
        variant: 'primary',
        text: 'Email material review',
        href: 'mailto:info@szcomo.com',
      },
      { text: 'RFQ inputs', href: '/rfq' },
    ]}
    image={{
      src: '~/assets/images/copper/hero-copper-parts-transparent.webp',
      alt: 'Copper additive manufacturing material review parts',
      class: 'mx-auto w-full',
    }}
  />

  <Features2
    title="Common material paths"
    subtitle="The right route is selected against the function of the part, not by material name alone."
    columns={3}
    items={[
      {
        title: 'Pure copper',
        description:
          'Best reviewed when electrical or thermal conductivity is dominant, mechanical loads are controlled, and final conductivity is more important than strength.',
        icon: 'tabler:hexagon-letter-c',
      },
      {
        title: 'CuCrZr',
        description:
          'Useful when the part needs more strength, clamp-load stability, or softening resistance while retaining useful conductivity after heat treatment.',
        icon: 'tabler:atom',
      },
      {
        title: 'GRCop-42',
        description:
          'Reviewed for high-temperature thermal hardware where alloy behavior, heat treatment, and documentation may matter.',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <SplitShowcase items={materialShowcases} classes={{ container: sectionContainerClass }} />

  <CallToAction
    classes={{ container: sectionContainerClass }}
    title="Not sure which copper alloy fits the part?"
    subtitle="Send the CAD package, quantity, operating conditions, and critical requirements so the material route can be reviewed as needed."
    actions={[
      {
        variant: 'primary',
        text: 'Email drawing for review',
        href: 'mailto:info@szcomo.com',
      },
    ]}
  />
</Layout>
