---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import Layout from '~/layouts/PageLayout.astro';
import { ceramicApplications, rfqEmailHref } from '~/data/ceramic';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const applicationShowcases = ceramicApplications.map((item, index) => ({
  id: item.id,
  imagePosition: index % 2 === 0 ? ('left' as const) : ('right' as const),
  image: {
    src: item.image,
    alt: item.alt,
  },
  title: item.title,
  description: item.description,
  points: item.points,
}));

const applicationFamilies = [
  {
    title: 'Semiconductor, vacuum, and high-voltage ceramics',
    description:
      'Wafer-handling hardware, insulating spacers, feedthrough-adjacent parts, and vacuum interfaces where cleanliness, flatness, edge radius, and datum evidence decide acceptance.',
    icon: 'tabler:device-analytics',
    callToAction: { text: 'View semiconductor case', href: '/applications/#semiconductor-ceramic-components' },
  },
  {
    title: 'Sealing, wear, and chemical hardware',
    description:
      'Valve seats, sealing rings, bearings, pump parts, SiC flow components, and corrosive-service hardware where Ra, flatness, roundness, and edge integrity control life.',
    icon: 'tabler:shield-check',
    callToAction: { text: 'View sealing case', href: '/applications/#ceramic-sealing-faces-valve-seats' },
  },
  {
    title: 'Micro-holes, nozzles, and flow features',
    description:
      'Sub-millimeter holes, jets, orifices, and restrictors reviewed for breakout, taper, concentricity, hole-to-edge distance, and optical or pin-gauge acceptance.',
    icon: 'tabler:focus-2',
    callToAction: { text: 'View micro-drilling case', href: '/applications/#micro-drilling-precision-orifices' },
  },
  {
    title: 'Flats, bores, and reference geometry',
    description:
      'Lapped surfaces, precision bores, coaxial sleeves, metrology plates, and alignment fixtures where the datum scheme must be stable and inspectable.',
    icon: 'tabler:ruler-measure',
    callToAction: {
      text: 'View precision flats case',
      href: '/applications/#precision-flats-parallels-lapped-surfaces',
    },
  },
  {
    title: 'Thin walls, pockets, and edge quality',
    description:
      'Machinable features that need realistic wall thickness, internal radii, slot geometry, chamfer or radius control, and clear chip criteria before a quote is meaningful.',
    icon: 'tabler:corner-down-right',
    callToAction: { text: 'View geometry case', href: '/applications/#slots-pockets-thin-wall-geometry' },
  },
  {
    title: 'Thermal fixtures and repeat programs',
    description:
      'Heat-resistant fixtures, spacers, prototypes, and small-batch programs where the first article locks material grade, process route, inspection packet, and packaging.',
    icon: 'tabler:temperature',
    callToAction: {
      text: 'View production case',
      href: '/applications/#prototyping-small-batch-repeat-orders',
    },
  },
];

const applicationGuideLinks = [
  {
    title: 'Precision semiconductor ceramic components',
    description:
      'Wafer handling parts, vacuum chucks, SiC rings, AlN plates, alumina insulators, micro-holes, and inspection review.',
    icon: 'tabler:device-analytics',
    callToAction: {
      text: 'Read semiconductor guide',
      href: '/posts/semiconductor-equipment/precision-ceramic-components-semiconductor-equipment/',
    },
  },
  {
    title: 'SiC wafer handling components',
    description:
      'End effectors, lift pins, support pads, wafer-contact surfaces, edge quality, cleaning, packaging, and inspection evidence.',
    icon: 'tabler:affiliate',
    callToAction: {
      text: 'Read SiC handling guide',
      href: '/posts/semiconductor-equipment/silicon-carbide-wafer-handling-components-semiconductor-manufacturing/',
    },
  },
  {
    title: 'Ceramic vacuum chucks',
    description:
      'Flatness, hole fields, porous surfaces, grooves, datum strategy, vacuum behavior, cleaning, and inspection evidence.',
    icon: 'tabler:circle-dot',
    callToAction: {
      text: 'Read vacuum chuck guide',
      href: '/posts/vacuum-chucks/ceramic-vacuum-chuck-flatness-rfq/',
    },
  },
  {
    title: 'Micro-holes and orifices',
    description:
      'Gas plates, nozzles, vacuum features, hole depth, taper, entry and exit breakout, cleaning, and measurement method.',
    icon: 'tabler:focus-2',
    callToAction: {
      text: 'Read micro-hole guide',
      href: '/posts/micro-hole-machining/ceramic-micro-hole-machining-rfq/',
    },
  },
  {
    title: 'Lapped seal faces',
    description:
      'Seal bands, valve seats, lapping scope, flatness, Ra, edge quality, paired faces, and acceptance reporting.',
    icon: 'tabler:circles-relation',
    callToAction: {
      text: 'Read seal face guide',
      href: '/posts/lapped-seal-faces/ceramic-lapped-seal-faces-rfq/',
    },
  },
  {
    title: 'Wear-resistant ceramic parts',
    description:
      'Bushings, liners, guide rails, seal faces, pins, rollers, valve parts, contact surfaces, and replacement geometry.',
    icon: 'tabler:shield-check',
    callToAction: {
      text: 'Read wear guide',
      href: '/posts/industrial-ceramic-machining/industrial-ceramic-machining-wear-resistant-components/',
    },
  },
  {
    title: 'High-voltage ceramic insulators',
    description:
      'Insulating spacers, sleeves, feedthrough-adjacent parts, creepage paths, edge condition, and assembly stress.',
    icon: 'tabler:bolt',
    callToAction: {
      text: 'Read insulation guide',
      href: '/posts/high-voltage-insulation/ceramic-high-voltage-insulators-rfq/',
    },
  },
  {
    title: 'Thermal management ceramics',
    description:
      'AlN plates, heat spreaders, power electronics fixtures, thermal-interface flatness, Ra, and cleanliness review.',
    icon: 'tabler:temperature',
    callToAction: {
      text: 'Read AlN guide',
      href: '/posts/industrial-ceramic-machining/aluminum-nitride-ceramic-machining-thermal-management-components/',
    },
  },
  {
    title: 'Harsh environment SiC parts',
    description:
      'Chemical, abrasive, high-temperature, semiconductor, pump, valve, nozzle, and seal applications where SiC fits.',
    icon: 'tabler:flask',
    callToAction: {
      text: 'Read SiC guide',
      href: '/posts/industrial-ceramic-machining/silicon-carbide-ceramic-machining-harsh-environment-applications/',
    },
  },
  {
    title: 'High-temperature BN parts',
    description:
      'BN insulators, furnace fixtures, tubes, spacers, molten-metal-adjacent nozzles, atmosphere limits, and RFQ inputs.',
    icon: 'tabler:flame',
    callToAction: {
      text: 'Read BN guide',
      href: '/posts/industrial-ceramic-machining/boron-nitride-ceramic-machining-high-temperature-insulation-parts/',
    },
  },
];

const metadata = {
  title: 'Advanced Ceramic CNC Machining Applications',
  description:
    'Precision ceramic CNC application cases for semiconductor, vacuum, sealing, wear, micro-hole, thin-wall, nozzle, bore, flatness, and edge-quality parts.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/application-1.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Applications', item: '/applications/' },
    ]),
    createItemListSchema(
      'Advanced ceramic CNC machining applications',
      ceramicApplications.map((item) => ({
        name: item.title,
        description: item.description,
        url: `/applications/#${item.id}`,
      }))
    ),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Applications"
    title="Use ceramic CNC where geometry, surface integrity, and inspection decide success"
    subtitle="Start from the application need, then define material grade, datums, functional faces, edge condition, surface finish, and evidence required for acceptance."
    actions={[
      {
        variant: 'primary',
        text: 'Email technical RFQ',
        href: rfqEmailHref,
      },
      { text: 'RFQ checklist', href: '/rfq/' },
    ]}
    image={{
      src: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
      alt: 'Advanced ceramic CNC machining application parts',
      class: 'mx-auto w-full',
    }}
  />

  <Features2
    title="Application families"
    subtitle="These categories mirror the RFQ patterns most likely to need ceramic machining feasibility review before price and schedule are confirmed."
    columns={3}
    items={applicationFamilies}
  />

  <SplitShowcase
    title="Application-specific review"
    subtitle="Each case below is mapped to feature feasibility, failure modes, inspection logic, and RFQ inputs."
    tagline="Use cases"
    items={applicationShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <Features2
    title="Requirements that affect quotation"
    subtitle="Ceramic parts quote differently when precision is localized to functional interfaces instead of applied globally."
    columns={3}
    items={[
      {
        title: 'Functional surfaces',
        description:
          'Seal faces, bearing fits, datum pads, bores, orifice edges, and alignment features should be marked on the drawing.',
        icon: 'tabler:target',
      },
      {
        title: 'Edge quality',
        description:
          'Define chamfer, radius, and allowable chip size by zone so handling edges do not become hidden crack origins.',
        icon: 'tabler:corner-down-right',
      },
      {
        title: 'Surface finish',
        description:
          'Ra, lapping, polishing, and surface integrity should be applied to faces that drive sealing, wear, cleanability, or friction.',
        icon: 'tabler:ruler-measure',
      },
      {
        title: 'Micro-features',
        description:
          'Micro-holes, narrow slots, thin walls, and internal radii need diameter, depth, taper, edge condition, and inspection method.',
        icon: 'tabler:focus-2',
      },
      {
        title: 'Material grade',
        description:
          'A generic material name is not enough for critical applications. Specify grade, density, purity, or performance targets.',
        icon: 'tabler:atom',
      },
      {
        title: 'Inspection packet',
        description:
          'CMM, profile, optical, surface finish, flatness mapping, special inspection, and key-dimension reports should match acceptance risk.',
        icon: 'tabler:clipboard-check',
      },
    ]}
  />

  <Features2
    title="Application engineering guides"
    subtitle="These internal guides connect application intent to material choice, precision features, surface requirements, and RFQ evidence."
    columns={3}
    items={applicationGuideLinks}
    classes={{ container: sectionContainerClass }}
  />

  <CallToAction
    classes={{ container: sectionContainerClass }}
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: rfqEmailHref,
      },
    ]}
    title="Need review for a precision ceramic part?"
    subtitle="Send CAD, drawings, material grade, blank or sourcing requirement, quantity, target lead time, functional surfaces, edge requirements, and inspection expectations for feasibility and quotation review."
  />
</Layout>
