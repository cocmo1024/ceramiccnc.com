---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import Layout from '~/layouts/PageLayout.astro';
import { ceramicApplications, rfqEmailHref } from '~/data/ceramic';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const applicationShowcases = ceramicApplications.map((item, index) => ({
  id: item.id,
  imagePosition: index % 2 === 0 ? ('left' as const) : ('right' as const),
  image: {
    src: item.image,
    alt: item.alt,
  },
  title: item.title,
  description: item.description,
  points: item.points,
}));

const applicationFamilies = [
  {
    title: 'Semiconductor, vacuum, and HV ceramics',
    description:
      'Wafer-handling hardware, insulating spacers, feedthrough-adjacent parts, and vacuum interfaces where cleanliness, flatness, edge radius, and datum evidence decide acceptance.',
    icon: 'tabler:device-analytics',
    callToAction: { text: 'View semiconductor case', href: '/applications#semiconductor-ceramic-components' },
  },
  {
    title: 'Sealing, wear, and chemical hardware',
    description:
      'Valve seats, sealing rings, bearings, pump parts, SiC flow components, and corrosive-service hardware where Ra, flatness, roundness, and edge integrity control life.',
    icon: 'tabler:shield-check',
    callToAction: { text: 'View sealing case', href: '/applications#ceramic-sealing-faces-valve-seats' },
  },
  {
    title: 'Micro-holes, nozzles, and flow features',
    description:
      'Sub-millimeter holes, jets, orifices, and restrictors reviewed for breakout, taper, concentricity, hole-to-edge distance, and optical or pin-gage acceptance.',
    icon: 'tabler:focus-2',
    callToAction: { text: 'View micro-drilling case', href: '/applications#micro-drilling-precision-orifices' },
  },
  {
    title: 'Flats, bores, and reference geometry',
    description:
      'Lapped surfaces, precision bores, coaxial sleeves, metrology plates, and alignment fixtures where the datum scheme must be stable and inspectable.',
    icon: 'tabler:ruler-measure',
    callToAction: {
      text: 'View precision flats case',
      href: '/applications#precision-flats-parallels-lapped-surfaces',
    },
  },
  {
    title: 'Thin walls, pockets, and edge quality',
    description:
      'Machinable features that need realistic wall thickness, internal radii, slot geometry, chamfer or radius control, and clear chip criteria before a quote is meaningful.',
    icon: 'tabler:corner-down-right',
    callToAction: { text: 'View geometry case', href: '/applications#slots-pockets-thin-wall-geometry' },
  },
  {
    title: 'Thermal fixtures and repeat programs',
    description:
      'Heat-resistant fixtures, spacers, prototypes, and small-batch programs where the first article locks material grade, process route, inspection packet, and packaging.',
    icon: 'tabler:temperature',
    callToAction: {
      text: 'View production case',
      href: '/applications#prototyping-small-batch-repeat-orders',
    },
  },
];

const metadata = {
  title: 'Advanced Ceramic CNC Machining Applications',
  description:
    'Application hubs for precision ceramic CNC machining: semiconductor ceramics, sealing faces, micro-drilling, insulators, wear parts, flats, thin walls, vacuum hardware, nozzles, bores, and edge quality.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/application-1.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Applications', item: '/applications' },
    ]),
    createItemListSchema(
      'Advanced ceramic CNC machining applications',
      ceramicApplications.map((item) => ({
        name: item.title,
        description: item.description,
        url: `/applications#${item.id}`,
      }))
    ),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Applications"
    title="Use ceramic CNC where geometry, surface integrity, and inspection decide success"
    subtitle="Start from the application need, then define material grade, datums, functional faces, edge condition, surface finish, and evidence required for acceptance."
    actions={[
      {
        variant: 'primary',
        text: 'Email technical RFQ',
        href: rfqEmailHref,
      },
      { text: 'RFQ checklist', href: '/rfq' },
    ]}
    image={{
      src: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
      alt: 'Advanced ceramic CNC machining application parts',
      class: 'mx-auto w-full',
    }}
  />

  <Features2
    title="Application families"
    subtitle="These categories mirror the RFQ patterns most likely to need ceramic machining feasibility review before a reliable quote."
    columns={3}
    items={applicationFamilies}
  />

  <SplitShowcase
    title="Application-specific review"
    subtitle="Each case below is mapped to feature feasibility, failure modes, inspection logic, and RFQ inputs."
    tagline="Use cases"
    items={applicationShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <Features2
    title="Requirements that affect quotation"
    subtitle="Ceramic parts quote differently when precision is localized to functional interfaces instead of applied globally."
    columns={3}
    items={[
      {
        title: 'Functional surfaces',
        description:
          'Seal faces, bearing fits, datum pads, bores, orifice edges, and alignment features should be marked on the drawing.',
        icon: 'tabler:target',
      },
      {
        title: 'Edge quality',
        description:
          'Define chamfer, radius, and allowable chip size by zone so handling edges do not become hidden crack origins.',
        icon: 'tabler:corner-down-right',
      },
      {
        title: 'Surface finish',
        description:
          'Ra, lapping, polishing, and surface integrity should be applied to faces that drive sealing, wear, cleanability, or friction.',
        icon: 'tabler:ruler-measure',
      },
      {
        title: 'Micro-features',
        description:
          'Micro-holes, narrow slots, thin walls, and internal radii need diameter, depth, taper, edge condition, and inspection method.',
        icon: 'tabler:focus-2',
      },
      {
        title: 'Material grade',
        description:
          'A generic material name is not enough for critical applications. Specify grade, density, purity, or performance targets.',
        icon: 'tabler:atom',
      },
      {
        title: 'Inspection packet',
        description:
          'CMM, profile, optical, CT, surface finish, flatness mapping, and key-dimension reports should match acceptance risk.',
        icon: 'tabler:clipboard-check',
      },
    ]}
  />

  <CallToAction
    classes={{ container: sectionContainerClass }}
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: rfqEmailHref,
      },
    ]}
    title="Need a quote for a precision ceramic part?"
    subtitle="Send CAD, drawings, material grade, quantity, lead time, functional surfaces, edge requirements, and inspection expectations."
  />
</Layout>
