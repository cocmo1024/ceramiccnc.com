---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const rfqEmail = 'info@szcomo.com';
const rfqEmailHref = 'mailto:info@szcomo.com';
const sectionContainerClass = 'py-10 md:py-12 lg:py-14';
const rfqTemplate = `Subject: Copper 3D printing RFQ - [part name]

Hello COPPER 3DP,

Please review the attached CAD/drawings for quotation.

Part/application:
Attached files:
Quantity:
Material preference, if known:
Target lead time:
Critical dimensions or surfaces:
Operating conditions:
Inspection or test requirements:
Post-processing expected:

Notes:

Best regards,`;

const rfqShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/copper/rfq-review-workspace.webp',
      alt: 'Copper AM RFQ review workspace',
    },
    title: 'How we handle different RFQs',
    description: 'The response depends on the part and the information provided.',
    points: [
      {
        title: 'Simple drawing quote',
        description: 'If geometry and quantity are clear, we can provide a basic quote with normal assumptions.',
      },
      {
        title: 'Clarification needed',
        description:
          'If material, tolerance, pressure, current, thermal load, or inspection needs are unclear, we ask focused questions before quoting.',
      },
      {
        title: 'Complex project review',
        description:
          'For demanding parts, we discuss process route, post-processing, inspection, and lead-time drivers as needed.',
      },
    ],
  },
  {
    imagePosition: 'right' as const,
    image: {
      src: '~/assets/images/copper/high-current-busbars.webp',
      alt: 'Copper AM RFQ review inputs',
    },
    title: 'Information that helps quotation',
    description: 'Do not overprepare if the project is simple; send what you have and note what is critical.',
    points: [
      {
        title: 'Geometry package',
        description:
          'STEP, X_T, or native CAD files plus 2D drawings for critical dimensions, datum faces, sealing lands, contact surfaces, and threaded ports.',
      },
      {
        title: 'Functional requirements',
        description:
          'Heat load, coolant, flow rate, pressure drop, current, duty cycle, frequency band, vacuum exposure, and service temperature.',
      },
      {
        title: 'Special requirements',
        description:
          'Material, quantity, lead time, CT scope, pressure or helium leak test, dimensional inspection, surface finish, and post-processing intent.',
      },
    ],
  },
];

const metadata = {
  title: 'Copper AM RFQ Checklist | Drawings',
  description:
    'Copper AM RFQ checklist for CAD, drawings, quantity, material, lead time, heat load, current, RF band, CT, leak testing, and other requirements.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/copper/high-current-busbars.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'RFQ Inputs', item: '/rfq' },
    ]),
    createItemListSchema('Copper AM RFQ checklist', [
      {
        name: 'Geometry package',
        description: 'STEP, X_T, native CAD, and 2D drawings for critical faces, ports, threads, and dimensions.',
        url: '/rfq',
      },
      {
        name: 'Functional requirements',
        description:
          'Heat load, coolant, flow rate, pressure drop, current, frequency band, vacuum, or service temperature.',
        url: '/rfq',
      },
      {
        name: 'Special requirements',
        description:
          'CT scope, pressure or helium leak test, dimensional inspection, thermal test, and cleaning requirement.',
        url: '/rfq',
      },
    ]),
  ],
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="RFQ inputs"
    title="Send enough information for a practical copper AM quote"
    subtitle="A simple drawing and quantity can be enough for a first quote. For complex thermal, electrical, or fluid parts, include the requirements that affect material, post-processing, and testing."
  />

  <section class="relative not-prose py-10 md:py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div
        class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900 md:p-8"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">Email format</p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight dark:text-white">Use this structure if it helps.</h2>
            <p class="mt-3 max-w-3xl text-muted dark:text-slate-300">
              Send the drawing and what you know. Leave unknown fields blank rather than guessing.
            </p>
          </div>
          <a
            class="inline-flex shrink-0 items-center justify-center rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50 dark:border-slate-600 dark:text-white dark:hover:bg-slate-800"
            href={rfqEmailHref}
          >
            Email {rfqEmail}
          </a>
        </div>

        <pre
          id="rfq-email-template"
          class="mt-6 overflow-x-auto whitespace-pre-wrap rounded-md bg-slate-950 p-5 text-sm leading-6 text-slate-100">{rfqTemplate}</pre>

        <button
          type="button"
          data-aw-copy-rfq-template
          data-aw-copy-target="rfq-email-template"
          class="mt-4 inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-secondary"
        >
          Copy RFQ email template
        </button>
      </div>
    </div>
  </section>

  <SplitShowcase
    title="RFQ review flow"
    tagline="Practical inputs"
    subtitle="Send the drawing first. Add the requirements that affect quotation and acceptance."
    items={rfqShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <FAQs
    title="RFQ FAQs"
    subtitle="These questions usually determine whether a copper AM quote can move quickly."
    columns={1}
    items={[
      {
        title: 'Will every RFQ receive the same response?',
        description:
          'No. If the drawing and quantity are clear, the reply may be a basic quote. If key requirements are missing, we ask clarification questions first.',
      },
      {
        title: 'Can I send an early concept?',
        description:
          'Yes. Early CAD is useful for a first review, but quotation usually needs material, quantity, lead time, and any critical requirements.',
      },
      {
        title: 'Do you need a drawing if CAD is available?',
        description:
          'Drawings are recommended for critical dimensions, datum faces, flatness, sealing lands, thread notes, surface finish, and inspection scope.',
      },
      {
        title: 'What if the material is not decided?',
        description:
          'Send the service temperature, conductivity target, mechanical load, and environment so pure copper, CuCrZr, or GRCop-42 can be reviewed.',
      },
      {
        title: 'How are internal channels accepted?',
        description:
          'Internal passages should define CT scope, pressure or leak targets, flow rate, pressure drop, cleaning method, and allowable blockage risk.',
      },
      {
        title: 'What affects lead time most?',
        description:
          'Geometry review, build orientation, post-machining, heat treatment, CT or leak testing, surface requirements, and material availability.',
      },
    ]}
  />

  <Features3
    title="Related RFQ guides"
    subtitle="Use these when the project needs more than a simple drawing-and-quantity quote."
    columns={3}
    items={[
      {
        title: 'Copper 3D printing service',
        description:
          'A practical guide to CAD, drawings, quantity, materials, operating requirements, post-processing, and inspection scope.',
        icon: 'tabler:file-description',
        callToAction: {
          text: 'Read service RFQ guide',
          href: '/posts/EngineeringGuide/copper-3d-printing-service-rfq-guide/',
        },
      },
      {
        title: 'Process route selection',
        description:
          'Compare LPBF copper AM, CNC, brazing, skiving, EDM, and conventional routes before locking the quote path.',
        icon: 'tabler:route',
        callToAction: {
          text: 'Read process guide',
          href: '/posts/EngineeringGuide/copper-am-process-selection-lpbf-cnc-brazing/',
        },
      },
      {
        title: 'Busbars and coils',
        description:
          'RFQ inputs for current path, duty cycle, contact faces, cooling, insulation, plating, and inspection.',
        icon: 'tabler:bolt',
        callToAction: {
          text: 'Read electrical RFQ guide',
          href: '/posts/EngineeringGuide/3d-printed-copper-busbars-induction-coils-rfq/',
        },
      },
    ]}
  />

  <CallToAction
    title="Send the drawing and requirements"
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: rfqEmailHref,
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="subtitle">
      Email <a class="font-semibold underline underline-offset-4" href={rfqEmailHref}>{rfqEmail}</a> with CAD, drawings, quantity,
      material if known, lead time, service conditions, and inspection requirements when they matter.
    </Fragment>
  </CallToAction>
</Layout>
