---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { ceramicFaqItems, engineeringArticles, rfqEmail, rfqEmailHref } from '~/data/ceramic';
import { createBreadcrumbSchema, createFAQPageSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';
const rfqTemplate = `Subject: Precision Ceramic CNC RFQ - [material/grade] - [quantity] - [target date]

Hello CERAMIC CNC,

Please review the attached CAD/drawings for quotation.

Part/application:
Ceramic material, grade, and fired state:
Customer-supplied blanks or sourcing requested:
Attached files:
Quantity:
Target lead time:
Critical dimensions, datums, and GD&T:
Surface finish, flatness, or lapping requirements:
Micro-holes, slots, thin walls, or edge-break requirements:
Operating environment:
Inspection method, documentation, and certificate requirements:
Acceptance criteria or sampling plan:
Ship-to country/region:

Notes:

Best regards,`;

const rfqShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/ceramic/application-9.webp',
      alt: 'Ceramic RFQ metrology and datum review workspace',
    },
    title: 'How we handle different RFQs',
    description:
      'The response depends on whether the drawing, material route, functional surfaces, and acceptance evidence are clear.',
    points: [
      {
        title: 'Simple drawing quote',
        description:
          'If material, geometry, quantity, and standard tolerances are clear, we can review the project for quotation with route assumptions.',
      },
      {
        title: 'Clarification needed',
        description:
          'If datums, edge condition, surface finish, material grade, micro-features, or inspection needs are missing, we ask before quoting.',
      },
      {
        title: 'Complex project review',
        description:
          'For sealing, vacuum, semiconductor, micro-hole, or tight flatness requirements, feasibility notes and inspection scope are part of the quote path.',
      },
    ],
  },
  {
    imagePosition: 'right' as const,
    image: {
      src: '~/assets/images/ceramic/application-3.webp',
      alt: 'Ceramic micro-drilling RFQ inputs',
    },
    title: 'Information that helps quotation',
    description:
      'Send what you have and clearly mark what is function-critical. Leave unknown fields blank rather than guessing.',
    points: [
      {
        title: 'Geometry package',
        description:
          'STEP, IGES, native CAD, and 2D drawings with revision, datums, GD&T, critical interfaces, and inspectable features.',
      },
      {
        title: 'Functional requirements',
        description:
          'Temperature, media chemistry, wear/erosion, vacuum, dielectric, thermal cycling, flow, sealing, or assembly constraints.',
      },
      {
        title: 'Acceptance evidence',
        description:
          'CMM, optical, profile, pin gauge, surface finish, flatness mapping, CoC, available material certificate, CT when justified, or key-dimension report.',
      },
    ],
  },
];

const metadata = {
  title: 'Ceramic CNC RFQ Checklist',
  description:
    'Ceramic CNC RFQ checklist for drawings, CAD, material grade, blank source, quantity, tolerances, micro-holes, surface finish, and inspection reports.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/application-9.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'RFQ Inputs', item: '/rfq/' },
    ]),
    createItemListSchema('Ceramic CNC RFQ checklist', [
      {
        name: 'Geometry package',
        description: 'STEP, IGES, native CAD, and drawings for critical faces, datums, holes, slots, and dimensions.',
        url: '/rfq/',
      },
      {
        name: 'Functional requirements',
        description: 'Temperature, media, wear, vacuum, insulation, flow, sealing, and assembly constraints.',
        url: '/rfq/',
      },
      {
        name: 'Inspection requirements',
        description:
          'CMM, optical, profile, surface finish, flatness, CoC, material cert availability, special inspection, and key-dimension reports.',
        url: '/rfq/',
      },
    ]),
    createFAQPageSchema(ceramicFaqItems.slice(0, 12)),
  ],
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="RFQ inputs"
    title="Send enough information for a practical ceramic CNC quote"
    subtitle="A simple drawing and quantity may be enough to start review. For precision ceramic parts, include the requirements that affect blank source, material route, grinding allowance, surface finish, edge quality, and inspection."
  />

  <section class="relative not-prose py-10 md:py-14">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div
        class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900 md:p-8"
      >
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">Email format</p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight dark:text-white">Use this structure if it helps.</h2>
            <p class="mt-3 max-w-3xl text-muted dark:text-slate-300">
              Send the drawing and what you know. Unknown fields can stay blank.
            </p>
          </div>
          <a
            class="inline-flex shrink-0 items-center justify-center rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50 dark:border-slate-600 dark:text-white dark:hover:bg-slate-800"
            href={rfqEmailHref}
          >
            Email {rfqEmail}
          </a>
        </div>

        <pre
          id="rfq-email-template"
          class="mt-6 overflow-x-auto whitespace-pre-wrap rounded-md bg-slate-950 p-5 text-sm leading-6 text-slate-100">{rfqTemplate}</pre>

        <button
          type="button"
          data-aw-copy-rfq-template
          data-aw-copy-target="rfq-email-template"
          class="mt-4 inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-secondary"
        >
          Copy RFQ email template
        </button>
      </div>
    </div>
  </section>

  <SplitShowcase
    title="RFQ review flow"
    tagline="Practical inputs"
    subtitle="Send the drawing first. Add the ceramic-specific requirements that affect quotation and acceptance."
    items={rfqShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <FAQs
    title="RFQ FAQs"
    subtitle="These questions usually determine whether a ceramic CNC RFQ can be reviewed without avoidable back-and-forth."
    columns={1}
    items={ceramicFaqItems.slice(0, 12)}
  />

  <Features3
    title="Related RFQ guides"
    subtitle="Use these when the project needs more than a simple drawing-and-quantity quote."
    columns={3}
    items={engineeringArticles.slice(0, 6).map((article) => ({
      title: article.title,
      description: article.description,
      icon: 'tabler:file-description',
      callToAction: {
        text: 'Read guide',
        href: article.href,
      },
    }))}
  />

  <CallToAction
    title="Send the drawing and requirements"
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: rfqEmailHref,
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="subtitle">
      Email <a class="font-semibold underline underline-offset-4" href={rfqEmailHref}>{rfqEmail}</a> with CAD, drawings, material
      grade, blank or sourcing requirement, quantity, target lead time, critical surfaces, edge requirements, and inspection
      expectations. We review the information before confirming feasibility, price, or schedule.
    </Fragment>
  </CallToAction>
</Layout>
