---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
// import PostTags from "~/components/blog/Tags.astro";

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';
import { getBlogPermalink, getPermalink } from '~/utils/permalinks';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

// const allCategories = await findCategories();
// const allTags = await findTags();

const metadata = {
  title: `Engineering Guide${currentPage > 1 ? ` | Page ${currentPage}` : ''}`,
  description:
    'Engineering articles for ceramic CNC tolerances, surface finish, DFM rules, green machining, diamond grinding, inspection, and RFQ preparation.',
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Engineering Guide', item: getBlogPermalink() },
    ]),
    createItemListSchema(
      `Engineering Guide articles${currentPage > 1 ? ` page ${currentPage}` : ''}`,
      page.data.map((post) => ({
        name: post.title,
        description: post.excerpt,
        url: getPermalink(post.permalink, 'post'),
      }))
    ),
  ],
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-5xl">
    <Headline
      subtitle="Engineering notes for ceramic tolerances, surface finish, DFM rules, process routing, inspection planning, and RFQ preparation."
    >
      Engineering Guide
    </Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    <!--
      <PostTags tags={allCategories} class="mb-2" title="Search by Categories:" isCategory />
      <PostTags tags={allTags}  title="Search by Tags:" />
    -->
  </section>
</Layout>
