---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { ceramicApplications, ceramicCapabilities, ceramicFaqItems, rfqEmail, rfqEmailHref } from '~/data/ceramic';
import { createCeramicServiceSchema, createFAQPageSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const applicationShowcases = ceramicApplications.map((item, index) => ({
  imagePosition: index % 2 === 0 ? ('left' as const) : ('right' as const),
  image: {
    src: item.image,
    alt: item.alt,
  },
  title: item.title,
  description: item.description,
  points: [
    ...item.points,
    {
      title: 'RFQ next step',
      description:
        'Send drawing, STEP file, material grade, quantity, critical datums, surface finish, and inspection needs.',
      callToAction: { text: 'Open application details', href: `/applications/#${item.id}` },
    },
  ],
}));

const requirementShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/ceramic/application-6.webp',
      alt: 'Precision ceramic flatness, lapping, and inspection planning',
    },
    title: 'From drawing review to ceramic quotation',
    description:
      'Simple ceramic parts may need only a basic review before quotation. Precision parts need material grade, datums, surface requirements, and inspection evidence checked first.',
    points: [
      {
        title: 'Material and grade',
        description:
          'Al2O3, ZrO2, Si3N4, SiC, MACOR, AlN, BN, fused silica, and selected technical ceramics are reviewed against the operating requirement.',
      },
      {
        title: 'Feature and finishing limits',
        description:
          'Thin walls, slots, micro-holes, ground faces, lapping allowance, edge condition, and surface finish targets affect feasibility and cost.',
      },
      {
        title: 'Inspection needs',
        description:
          'CMM, optical checks, profile, flatness mapping, Ra, CT, material certificate, and key-dimension reports are considered when required.',
      },
      {
        title: 'Clarification when needed',
        description:
          'If datums, grade, edge quality, or inspection expectations are unclear, we ask before quoting rather than assuming a risky ceramic route.',
        callToAction: {
          text: 'Ceramic RFQ checklist',
          href: '/rfq/',
        },
      },
    ],
  },
];

const metadata = {
  title: 'Precision Ceramic CNC Machining | CERAMIC CNC',
  ignoreTitleTemplate: true,
  description:
    'Precision ceramic CNC machining, diamond grinding, lapping, micro-drilling, edge control, CMM and CT inspection, and RFQ review for Al2O3, ZrO2, Si3N4, SiC, and MACOR.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createCeramicServiceSchema(),
    createItemListSchema(
      'Engineering-critical ceramic machining application cases',
      ceramicApplications.map((item) => ({
        name: item.title,
        description: item.description,
        url: `/applications/#${item.id}`,
      }))
    ),
    createFAQPageSchema(ceramicFaqItems.slice(0, 10)),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Email technical RFQ',
        href: rfqEmailHref,
        icon: 'tabler:mail',
      },
      { text: 'Browse Engineering Guide', href: '/category/engineering-guide/' },
    ]}
    image={{
      src: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
      alt: 'Precision ceramic CNC machining, grinding, and micro-drilling parts',
      class:
        'mx-auto w-full drop-shadow-[0_24px_44px_rgba(15,23,42,0.20)] dark:drop-shadow-[0_28px_52px_rgba(148,163,184,0.16)]',
    }}
  >
    <Fragment slot="title">
      Precision ceramic CNC machining for <span class="text-accent dark:text-white"
        >tolerances, surfaces, and feasibility-reviewed RFQs</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Built for engineering and procurement teams sourcing advanced ceramic parts. We convert brittle-material
      constraints such as diamond tool wear, edge chipping, datum stability, and subsurface damage into practical
      process planning, RFQ inputs, and inspection requirements before quotation.
    </Fragment>

    <Fragment slot="content">
      <p class="mt-4 text-sm text-muted dark:text-slate-300">
        Send drawing + STEP + material grade + quantity to{' '}
        <a class="font-semibold underline underline-offset-4" href={rfqEmailHref}>{rfqEmail}</a>.
      </p>
    </Fragment>
  </Hero>

  <Note
    title="RFQ checklist:"
    description="Include material grade, drawing and STEP, datums, GD&T, quantity, target lead time, surface finish or flatness targets, critical edges, and required evidence such as CMM, profile, Ra, CT, or key-dimension reports."
  />

  <section class:list={['relative not-prose', sectionContainerClass]}>
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">Good fit</p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight dark:text-white">
            Ceramic CNC is worth reviewing when interfaces and acceptance are measurable.
          </h2>
          <ul class="mt-4 space-y-2 text-muted dark:text-slate-300">
            <li>Seal faces, bores, datum pads, flatness, parallelism, edge quality, or Ra drive performance.</li>
            <li>
              The part uses advanced ceramics for wear, insulation, vacuum, thermal, chemical, or semiconductor service.
            </li>
            <li>Inspection evidence must align to drawing acceptance before procurement releases the order.</li>
          </ul>
        </div>
        <div class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
          <p class="text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
            Usually not ready
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight dark:text-white">
            Undefined precision creates quote variance and scrap risk.
          </h2>
          <ul class="mt-4 space-y-2 text-muted dark:text-slate-300">
            <li>All faces are marked tight without identifying the function-critical surfaces.</li>
            <li>Datums, edge condition, surface finish, and inspection method are missing or implied.</li>
            <li>
              The application needs metal-like ductility, impact tolerance, or uninspectable sharp internal geometry.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Features3
    title="What to send for review"
    subtitle="A simple drawing may be enough to start review. Complex ceramic parts need clearer material, feature, and inspection requirements before price or schedule are confirmed."
    columns={3}
    classes={{
      container: sectionContainerClass,
      items: {
        container: 'gap-x-12',
        panel: 'max-w-none',
      },
    }}
    items={[
      {
        title: 'Drawing package',
        description:
          'STEP, IGES, native CAD, or drawings with key dimensions, datum faces, bores, slots, holes, and critical surfaces.',
        icon: 'tabler:search',
      },
      {
        title: 'Quantity and timing',
        description:
          'Prototype quantity, batch size, target delivery date, material grade, and any purchasing or project constraints.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Special requirements',
        description:
          'Surface finish, flatness, lapping, edge condition, micro-features, CMM, CT, CoC, or material certificate when they matter.',
        icon: 'tabler:clipboard-check',
      },
    ]}
  />

  <SplitShowcase
    id="applications"
    tagline="Application hubs"
    title="15 engineering-critical ceramic machining use cases"
    subtitle="The strongest ceramic RFQs connect feature feasibility, failure modes, inspection method, and procurement acceptance before machining starts."
    items={applicationShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <SplitShowcase
    tagline="Feasibility first"
    title="Review ceramic machining from the actual requirement"
    items={requirementShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <Steps
    title="Simple RFQ flow"
    subtitle="A ceramic RFQ can be evaluated properly when the drawing, material route, and acceptance gate are clear."
    isReversed={true}
    classes={{
      container: sectionContainerClass,
      items: {
        title: 'text-lg font-semibold leading-6',
        description: 'text-sm leading-6',
        icon: 'h-9 w-9',
      },
    }}
    items={[
      {
        title: 'Step 1: <span class="font-medium">Send geometry</span>',
        description: 'Share drawing, STEP or IGES, revision, material grade, target quantity, and lead time.',
        icon: 'tabler:file-3d',
      },
      {
        title: 'Step 2: <span class="font-medium">Mark functional requirements</span>',
        description: 'Identify datums, seal faces, bores, micro-holes, thin walls, edges, Ra, flatness, and CTQs.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Step 3: <span class="font-medium">Select inspection evidence</span>',
        description:
          'State whether CMM, optical, profile, surface finish, flatness mapping, CT, or key-dimension reports are required.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Step 4: <span class="font-medium">Quote or clarify</span>',
        description:
          'After review, we respond with feasibility notes, route assumptions, quotation details, or focused clarification questions.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '~/assets/images/ceramic/application-9.webp',
      alt: 'Ceramic RFQ review and inspection planning workflow',
    }}
  />

  <Features2
    title="What we review before quoting"
    subtitle="The review depth depends on material, feature risk, tolerance stack-up, and required evidence."
    tagline="Engineering review"
    classes={{ container: sectionContainerClass }}
    items={ceramicCapabilities}
  />

  <BlogLatestPosts
    title="Engineering resources"
    information="Use these notes to prepare RFQs for tolerance capability, surface finish, DFM rules, green versus hard machining, AM preforms, and diamond grinding procurement."
    classes={{ container: sectionContainerClass }}
  />

  <FAQs
    title="Frequently asked questions"
    subtitle="Common questions before quoting precision ceramic CNC machining and grinding projects."
    tagline="FAQs"
    classes={{ container: sectionContainerClass }}
    items={ceramicFaqItems.slice(0, 10)}
  />

  <Stats
    classes={{ container: sectionContainerClass }}
    stats={[
      { title: 'Application use cases', amount: '15' },
      { title: 'Core ceramic families', amount: '6+' },
      { title: 'Inspection methods', amount: 'CMM / Ra / CT' },
      { title: 'RFQ principle', amount: 'Review first' },
    ]}
  />

  <CallToAction
    classes={{ container: sectionContainerClass }}
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: rfqEmailHref,
        icon: 'tabler:mail',
      },
      {
        text: 'Prepare RFQ inputs',
        href: '/rfq/',
      },
    ]}
  >
    <Fragment slot="title">Send CAD for ceramic feasibility and quotation review.</Fragment>

    <Fragment slot="subtitle">
      Include drawing + STEP + material grade + quantity + target lead time + critical dimensions, datums, surface
      finish or flatness targets, and inspection evidence required for acceptance. We review these inputs before
      confirming feasibility, price, or schedule.
    </Fragment>
  </CallToAction>
</Layout>
