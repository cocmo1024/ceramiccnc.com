---
import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';
import { applicationHubs, type ApplicationHub } from '~/data/application-hubs';
import { rfqEmailHref } from '~/data/ceramic';
import { findPostsByIds } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';
import {
  createBreadcrumbSchema,
  createCeramicApplicationServiceSchema,
  createFAQPageSchema,
  createItemListSchema,
} from '~/utils/structured-data';

export const prerender = true;

export const getStaticPaths = (() =>
  applicationHubs.map((hub) => ({
    params: { slug: hub.slug },
    props: { hub },
  }))) satisfies GetStaticPaths;

const { hub } = Astro.props as { hub: ApplicationHub };
const hubUrl = `/applications/${hub.slug}/`;
const guides = await findPostsByIds(hub.guidePostIds);

const metadata = {
  title: hub.metaTitle,
  description: hub.description,
  openGraph: {
    images: [
      {
        url: hub.image,
        width: 1200,
        height: 628,
        alt: hub.imageAlt,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Applications', item: '/applications/' },
      { name: hub.title, item: hubUrl },
    ]),
    createCeramicApplicationServiceSchema({
      id: `applications/${hub.slug}`,
      name: hub.title,
      serviceType: `${hub.title} machining and RFQ review`,
      description: hub.description,
      url: hubUrl,
      audienceType: 'Industrial engineering, sourcing, equipment, quality, and procurement teams',
    }),
    createItemListSchema(
      `${hub.title} engineering guides`,
      guides.map((post) => ({
        name: post.title,
        description: post.excerpt,
        url: getPermalink(post.permalink, 'post'),
      }))
    ),
    createFAQPageSchema(hub.faqs),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline={hub.tagline}
    title={hub.title}
    subtitle={hub.summary}
    actions={[
      { variant: 'primary', text: 'Prepare an RFQ', href: '/rfq/' },
      { text: 'Email drawings', href: rfqEmailHref },
    ]}
    image={{
      src: hub.image,
      alt: hub.imageAlt,
      class: 'mx-auto w-full',
    }}
  />

  <section class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14" aria-labelledby="application-review-heading">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(16rem,0.55fr)] lg:items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Application review</p>
        <h2
          id="application-review-heading"
          class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white"
        >
          Start from the functional interface
        </h2>
        <div class="mt-5 space-y-4 text-base leading-7 text-muted dark:text-slate-300">
          {hub.overview.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>

      <aside class="border-l-2 border-primary/40 pl-5" aria-label="Core engineering routes">
        <h2 class="text-base font-semibold text-slate-900 dark:text-white">Core engineering routes</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6">
          <li>
            <a class="font-medium text-primary hover:underline dark:text-secondary" href="/capabilities/"
              >Machining capabilities</a
            >
          </li>
          <li>
            <a class="font-medium text-primary hover:underline dark:text-secondary" href="/materials/"
              >Ceramic material selection</a
            >
          </li>
          <li>
            <a
              class="font-medium text-primary hover:underline dark:text-secondary"
              href="/posts/tolerances-gdt/ceramic-tolerance-capability-map-by-feature-process/"
            >
              Tolerance capability map
            </a>
          </li>
          <li>
            <a
              class="font-medium text-primary hover:underline dark:text-secondary"
              href="/posts/rfq-preparation/custom-ceramic-cnc-machining-rfq-checklist/"
            >
              Ceramic CNC RFQ checklist
            </a>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="border-y border-slate-200/80 bg-slate-50/70 dark:border-slate-800 dark:bg-slate-950/50">
    <div class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Component families</p>
        <h2 class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white">
          Match the part family to its acceptance risk
        </h2>
        <p class="mt-3 leading-7 text-muted dark:text-slate-300">
          These are not catalog promises. They are review paths for connecting geometry, material, process, and evidence
          to the function of the part.
        </p>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          hub.componentFamilies.map((item) => (
            <article class="surface-panel p-5">
              <Icon name={item.icon || 'tabler:settings'} class="h-8 w-8 text-primary" />
              <h3 class="mt-4 text-lg font-semibold leading-6 text-slate-900 dark:text-white">{item.title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted dark:text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14" aria-labelledby="decision-map-heading">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Decision map</p>
      <h2 id="decision-map-heading" class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white">
        Requirements that change machining and quotation
      </h2>
      <p class="mt-3 leading-7 text-muted dark:text-slate-300">
        Use the final column as a drawing and RFQ check. A requirement is easier to review when its function and
        acceptance evidence are stated together.
      </p>
    </div>
    <div class="mt-8 overflow-x-auto rounded-md border border-slate-200/80 dark:border-slate-800">
      <table class="w-full min-w-[760px] border-collapse text-left text-sm">
        <thead class="bg-slate-100 text-slate-900 dark:bg-slate-900 dark:text-slate-100">
          <tr>
            <th scope="col" class="px-4 py-3 font-semibold">Requirement</th>
            <th scope="col" class="px-4 py-3 font-semibold">Why it changes the route</th>
            <th scope="col" class="px-4 py-3 font-semibold">What to define in the RFQ</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200/80 dark:divide-slate-800">
          {
            hub.decisions.map((row) => (
              <tr class="align-top">
                <th scope="row" class="px-4 py-4 font-semibold text-slate-900 dark:text-slate-100">
                  {row.requirement}
                </th>
                <td class="px-4 py-4 leading-6 text-muted dark:text-slate-300">{row.whyItMatters}</td>
                <td class="px-4 py-4 leading-6 text-muted dark:text-slate-300">{row.rfqEvidence}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="border-y border-slate-200/80 dark:border-slate-800">
    <div class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14">
      <div class="grid gap-10 lg:grid-cols-2">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Material paths</p>
          <h2 class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white">
            Select against the failure mode
          </h2>
          <div class="mt-6 space-y-5">
            {
              hub.materialPaths.map((item) => (
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-slate-100">{item.title}</h3>
                  <p class="mt-1 text-sm leading-6 text-muted dark:text-slate-300">{item.description}</p>
                </div>
              ))
            }
          </div>
          <a
            class="mt-6 inline-flex items-center gap-2 font-semibold text-primary hover:underline dark:text-secondary"
            href="/posts/materials-grade-selection/ceramic-material-selection-cnc-machining/"
          >
            Compare ceramic materials for CNC machining
            <Icon name="tabler:arrow-right" class="h-4 w-4" />
          </a>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Quote-ready package</p>
          <h2 class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white">
            Information to send for review
          </h2>
          <ol class="mt-6 space-y-3">
            {
              hub.rfqInputs.map((item, index) => (
                <li class="flex gap-3 text-sm leading-6 text-muted dark:text-slate-300">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-primary/40 text-xs font-semibold text-primary">
                    {index + 1}
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ol>
          <a
            class="mt-6 inline-flex items-center gap-2 font-semibold text-primary hover:underline dark:text-secondary"
            href="/rfq/"
          >
            Prepare the RFQ package
            <Icon name="tabler:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14" aria-labelledby="engineering-guides-heading">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Engineering guides</p>
      <h2
        id="engineering-guides-heading"
        class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white"
      >
        Continue by component, material, or acceptance problem
      </h2>
      <p class="mt-3 leading-7 text-muted dark:text-slate-300">
        Each guide below narrows one part family or manufacturing constraint and leads back to the drawing information
        needed for review.
      </p>
    </div>
    <div class="mt-8 grid gap-x-8 gap-y-6 md:grid-cols-2">
      {
        guides.map((post) => (
          <article class="border-t border-slate-200/80 pt-5 dark:border-slate-800">
            <h3 class="text-lg font-semibold leading-6">
              <a
                class="text-slate-900 underline-offset-4 hover:text-primary hover:underline dark:text-slate-100 dark:hover:text-secondary"
                href={getPermalink(post.permalink, 'post')}
              >
                {post.title}
              </a>
            </h3>
            <p class="mt-2 text-sm leading-6 text-muted dark:text-slate-300">{post.excerpt}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="border-y border-slate-200/80 bg-slate-50/70 dark:border-slate-800 dark:bg-slate-950/50">
    <div class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">Questions before quotation</p>
        <h2 class="mt-2 text-3xl font-semibold leading-tight text-slate-900 dark:text-white">Application RFQ FAQ</h2>
      </div>
      <div
        class="mt-7 divide-y divide-slate-200/80 border-y border-slate-200/80 dark:divide-slate-800 dark:border-slate-800"
      >
        {
          hub.faqs.map((item) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-900 dark:text-slate-100">
                {item.title}
                <Icon name="tabler:plus" class="h-5 w-5 shrink-0 transition group-open:rotate-45" />
              </summary>
              <p class="mt-3 max-w-4xl text-sm leading-6 text-muted dark:text-slate-300">{item.description}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CallToAction
    classes={{ container: 'py-10 md:py-14' }}
    title="Send the drawing and application requirements for review"
    subtitle="Include material or operating environment, quantity, target timing, functional surfaces, tolerance and finish priorities, cleaning, packaging, and inspection evidence. Feasibility, price, and lead time are confirmed after review."
    actions={[
      { variant: 'primary', text: 'Prepare an RFQ', href: '/rfq/' },
      { text: 'Email info@szcomo.com', href: rfqEmailHref },
    ]}
  />
</Layout>
