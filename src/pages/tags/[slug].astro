---
interface Props {
  target: string;
  title: string;
}

export function getStaticPaths() {
  const legacyTags: Record<string, Props> = {
    'multifunctional-copper-parts': {
      target: '/applications/',
      title: 'Copper Additive Manufacturing Applications',
    },
    'copper-busbars': {
      target: '/posts/EngineeringGuide/3d-printed-copper-busbars-induction-coils-rfq/',
      title: '3D Printed Copper Busbars and Induction Coils',
    },
    'micro-channel-heat-exchangers': {
      target: '/copper-cold-plates/',
      title: '3D Printed Copper Cold Plates',
    },
    'conformal-cooling-inserts': {
      target: '/applications/',
      title: 'Copper Additive Manufacturing Applications',
    },
    cucrzr: {
      target: '/materials/',
      title: 'Copper 3D Printing Materials',
    },
    'high-voltage-electrodes': {
      target: '/blog/tag/high-voltage-electrodes/',
      title: 'High Voltage Copper Electrodes',
    },
  };

  return Object.entries(legacyTags).map(([slug, props]) => ({
    params: { slug },
    props,
  }));
}

const { target, title } = Astro.props;
const canonical = new URL(target, 'https://copper3dp.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <title>{title} | COPPER 3DP</title>
    <meta name="description" content={`This legacy tag page has moved to ${title}.`} />
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>This page has moved. Continue to <a href={target}>{title}</a>.</p>
    </main>
  </body>
</html>
