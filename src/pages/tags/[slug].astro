---
interface Props {
  target: string;
  title: string;
}

export function getStaticPaths() {
  const legacyTags: Record<string, Props> = {
    'capability-map': {
      target: '/posts/tolerances-gdt/ceramic-tolerance-capability-map-by-feature-process/',
      title: 'Ceramic Tolerance Capability Map',
    },
    'tight-tolerances': {
      target: '/posts/tolerances-gdt/ceramic-tolerance-capability-map-by-feature-process/',
      title: 'Ceramic Tight Tolerances',
    },
    gdt: {
      target: '/posts/tolerances-gdt/ceramic-tolerance-capability-map-by-feature-process/',
      title: 'Ceramic GD&T',
    },
    'surface-finish': {
      target: '/posts/surface-finish-functional/ceramic-ssd-surface-finish-specify-control-price/',
      title: 'Ceramic Surface Finish',
    },
    'subsurface-damage': {
      target: '/posts/surface-finish-functional/ceramic-ssd-surface-finish-specify-control-price/',
      title: 'Ceramic Subsurface Damage',
    },
    'design-rules': {
      target: '/posts/design-rules-feature-dfam/ceramic-dfm-design-rules/',
      title: 'Ceramic DFM Design Rules',
    },
    'green-machining': {
      target: '/posts/process-routes-control/green-machining-vs-hard-machining/',
      title: 'Green Machining vs Hard Machining',
    },
    'diamond-grinding': {
      target: '/posts/feasibility-process-choice/ceramic-machining-guide/',
      title: 'Ceramic Diamond Grinding',
    },
  };

  return Object.entries(legacyTags).map(([slug, props]) => ({
    params: { slug },
    props,
  }));
}

const { target, title } = Astro.props;
const canonical = new URL(target, 'https://www.ceramiccnc.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <title>{title} | CERAMIC CNC</title>
    <meta name="description" content={`This legacy tag page has moved to ${title}.`} />
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>This page has moved. Continue to <a href={target}>{title}</a>.</p>
    </main>
  </body>
</html>
