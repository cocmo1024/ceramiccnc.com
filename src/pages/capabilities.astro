---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import Stats from '~/components/widgets/Stats.astro';
import Layout from '~/layouts/PageLayout.astro';
import { createBreadcrumbSchema, createItemListSchema } from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const capabilityShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/copper/semiconductor-copper-parts.webp',
      alt: 'Semiconductor copper hardware',
    },
    title: 'Process fit before quotation',
    description:
      'The practical route depends on geometry, material behavior, post-processing, and the function the part must prove.',
    points: [
      {
        title: 'LPBF copper builds',
        description:
          'Powder-bed builds are reviewed for compact parts with internal passages, complex flow paths, thin structures, or assembly consolidation goals.',
      },
      {
        title: 'DfAM feasibility',
        description:
          'Geometry review covers minimum channels, wall thickness, overhangs, support access, powder removal, and post-machining stock.',
      },
      {
        title: 'Post-processing intent',
        description:
          'Machining, heat treatment, polishing, cleaning, plating, and sealing surfaces are defined before build strategy is finalized.',
      },
    ],
  },
  {
    imagePosition: 'right' as const,
    image: {
      src: '~/assets/images/copper/copper-cold-plate-channels.webp',
      alt: 'Copper cold plate channels for inspection review',
    },
    title: 'Inspection requirements',
    description:
      'If the part has pressure, leak, CT, dimensional, or surface requirements, include them with the RFQ so they are considered during quotation.',
    points: [
      {
        title: 'Internal continuity',
        description:
          'CT scanning can check channel continuity, trapped powder risk, wall thickness around critical passages, and internal defect indications.',
      },
      {
        title: 'Pressure and leak targets',
        description:
          'Cold plates, manifolds, vacuum hardware, and hydrogen components need working pressure, proof pressure, hold time, and leak threshold.',
      },
      {
        title: 'Dimensional checks',
        description:
          'Datum faces, sealing lands, threaded interfaces, RF-critical surfaces, and electrical contact planes need inspection requirements stated.',
      },
    ],
  },
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/copper/rfq-review-workspace.webp',
      alt: 'Copper AM RFQ review workspace',
    },
    title: 'What helps us quote',
    description:
      'A useful RFQ connects the part geometry to quantity, operating environment, and any required testing.',
    points: [
      {
        title: 'Functional surfaces marked',
        description:
          'Identify sealing faces, datum structures, contact planes, coolant ports, electrical interfaces, and keep-out regions.',
      },
      {
        title: 'Service load defined',
        description:
          'Provide heat flux, coolant, pressure drop, current, duty cycle, RF band, vacuum exposure, or qualification constraints.',
      },
      {
        title: 'Testing requested',
        description:
          'Specify whether CT, leak testing, pressure testing, flow validation, material certification, or surface inspection is required.',
        callToAction: {
          text: 'Send RFQ inputs',
          href: 'mailto:info@szcomo.com',
        },
      },
    ],
  },
];

const metadata = {
  title: 'Copper AM Capabilities | DfAM & Inspection',
  description:
    'Copper AM capabilities for material review, LPBF DfAM, post-processing, thermal and electrical parts, CT, leak testing, and RF or vacuum requirements.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/copper/hero-1.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Capabilities', item: '/capabilities' },
    ]),
    createItemListSchema('Copper AM capability areas', [
      {
        name: 'Material and process fit',
        description:
          'Pure copper, CuCrZr, and GRCop-42 review against function, temperature, and project requirements.',
        url: '/capabilities#materials',
      },
      {
        name: 'Inspection requirements',
        description:
          'CT, leak, pressure, dimensional, flow, and certification requirements for function-critical copper parts.',
        url: '/capabilities#inspection',
      },
    ]),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Capabilities"
    actions={[
      {
        variant: 'primary',
        text: 'Email info@szcomo.com',
        href: 'mailto:info@szcomo.com',
        icon: 'tabler:mail',
      },
      { text: 'Review RFQ inputs', href: '/rfq' },
    ]}
    image={{
      src: '~/assets/images/copper/hero-copper-parts-transparent.webp',
      alt: 'Industrial copper additive manufacturing components',
      class: 'mx-auto w-full',
    }}
  >
    <Fragment slot="title">
      Engineering support for <br />
      <span class="text-accent dark:text-white">function-critical copper AM parts</span>
    </Fragment>

    <Fragment slot="subtitle">
      COPPER 3DP focuses on copper additive manufacturing. Send the drawing and requirements, and we assess material,
      manufacturability, post-processing, and testing needs as the project requires.
    </Fragment>
  </Hero>

  <Stats
    title="Review areas"
    stats={[
      { title: 'Copper alloy families', amount: '3' },
      { title: 'Application hubs', amount: '15' },
      { title: 'Inspection methods', amount: 'CT / leak / flow' },
      { title: 'RFQ inputs', amount: '8+' },
    ]}
  />

  <Features3
    id="materials"
    title="Materials and process fit"
    subtitle="The first decision is whether the material and process route can support the operating target and required post-processing."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Pure copper',
        description:
          'Reviewed when conductivity and heat-transfer path dominate the requirement, with post-processing planned around final performance.',
        icon: 'tabler:hexagon-letter-c',
      },
      {
        title: 'CuCrZr',
        description:
          'Considered when strength, thermal softening resistance, and service temperature matter alongside electrical or thermal conductivity.',
        icon: 'tabler:atom',
      },
      {
        title: 'GRCop-42',
        description:
          'Reviewed for aerospace and high-temperature programs where alloy behavior, heat treatment, and documentation may matter.',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <SplitShowcase
    id="inspection"
    title="Capability review modules"
    subtitle="The quote path is clearer when process fit, inspection, and acceptance needs are stated early."
    tagline="Engineering review"
    items={capabilityShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <Features2
    title="How we support the quote"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'Manufacturability review',
        description:
          'Review for manufacturability limits, risk drivers, design options, and whether AM is suitable for the part.',
        icon: 'tabler:messages',
      },
      {
        title: 'Quotation support',
        description:
          'Quotation support based on the drawing, quantity, material target, lead time, post-processing, and inspection requirements.',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>
