---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import SplitShowcase from '~/components/widgets/SplitShowcase.astro';
import Stats from '~/components/widgets/Stats.astro';
import Layout from '~/layouts/PageLayout.astro';
import { ceramicCapabilities, rfqEmailHref } from '~/data/ceramic';
import {
  createBreadcrumbSchema,
  createCeramicApplicationServiceSchema,
  createItemListSchema,
} from '~/utils/structured-data';

const sectionContainerClass = 'py-10 md:py-12 lg:py-14';

const capabilityShowcases = [
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/ceramic/application-7.webp',
      alt: 'Ceramic slots pockets and thin-wall geometry for manufacturability review',
    },
    title: 'Manufacturability before quotation',
    description:
      'Ceramic CNC feasibility depends on how the feature will be held, referenced, ground, protected, and inspected after sintering.',
    points: [
      {
        title: 'Geometry review',
        description:
          'Slots, pockets, thin walls, hole proximity, internal radii, and fragile edges are checked against material and tool access.',
      },
      {
        title: 'Datum strategy',
        description: 'Stable ground datums should be created before dependent features are finished or measured.',
      },
      {
        title: 'Route clarity',
        description:
          'As-sintered, green-machined, ground, lapped, or polished surfaces are separated so the quote does not assume precision everywhere.',
      },
    ],
  },
  {
    imagePosition: 'right' as const,
    image: {
      src: '~/assets/images/ceramic/application-6.webp',
      alt: 'Precision ceramic flatness grinding and lapping capability',
    },
    title: 'Grinding, lapping, and surface finish planning',
    description:
      'Flatness, parallelism, sealing faces, and low Ra requirements are route decisions, not afterthoughts.',
    points: [
      {
        title: 'Allowance planned upfront',
        description:
          'Grinding stock, lapping allowance, removal sequence, and edge protection should be part of the initial process plan.',
      },
      {
        title: 'Surface integrity',
        description:
          'A low Ra value does not automatically prove low subsurface damage; high-risk applications may need process evidence.',
      },
      {
        title: 'Cost control',
        description:
          'Localizing precision to functional faces reduces unnecessary lapping, handling, and inspection cycles.',
      },
    ],
  },
  {
    imagePosition: 'left' as const,
    image: {
      src: '~/assets/images/ceramic/application-9.webp',
      alt: 'Ceramic inspection and metrology fixture review',
    },
    title: 'Inspection and acceptance evidence',
    description:
      'The acceptance gate should be defined before machining: what is measured, how it is measured, and which result decides pass/fail.',
    points: [
      {
        title: 'Dimensional evidence',
        description:
          'CMM, optical measurement, profile, pin gauges, and key-dimension reports can be matched to feature size and tolerance.',
      },
      {
        title: 'Surface evidence',
        description:
          'Flatness mapping, Ra readings, lapped-surface notes, microscopy, or visual edge criteria may be needed for functional faces.',
      },
      {
        title: 'Internal evidence',
        description:
          'External CT, section-based checks, or additional evidence may be appropriate for internal geometry, micro-features, or high-risk blanks when specified.',
      },
    ],
  },
];

const metadata = {
  title: 'Ceramic CNC Machining Capabilities',
  description:
    'Precision ceramic CNC, diamond grinding, lapping, micro-drilling, edge control, Ra, CMM, optical, profile, and inspection planning for advanced ceramic parts.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/ceramic/application-6.webp',
        width: 1200,
        height: 628,
      },
    ],
    type: 'website',
  },
  structuredData: [
    createBreadcrumbSchema([
      { name: 'Home', item: '/' },
      { name: 'Capabilities', item: '/capabilities/' },
    ]),
    createCeramicApplicationServiceSchema({
      id: 'capabilities',
      name: 'Ceramic CNC Machining, Diamond Grinding, and Inspection Capabilities',
      serviceType: 'Precision ceramic CNC machining capability review',
      description:
        'Post-sinter ceramic machining, grinding, lapping, micro-drilling, edge quality, surface finish, and inspection planning for advanced ceramic components.',
      url: '/capabilities/',
      audienceType: 'Engineering and procurement teams sourcing precision ceramic components',
    }),
    createItemListSchema(
      'Ceramic CNC capability areas',
      ceramicCapabilities.map((item) => ({
        name: item.title,
        description: item.description,
        url: '/capabilities/',
      }))
    ),
  ],
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Capabilities"
    actions={[
      {
        variant: 'primary',
        text: 'Email technical RFQ',
        href: rfqEmailHref,
        icon: 'tabler:mail',
      },
      { text: 'Review RFQ inputs', href: '/rfq/' },
    ]}
    image={{
      src: '~/assets/images/ceramic/hero-ceramic-cnc.webp',
      alt: 'Precision ceramic CNC machining capability parts',
      class: 'mx-auto w-full',
    }}
  >
    <Fragment slot="title">
      Ceramic CNC machining capability built around <br />
      <span class="text-accent dark:text-white">datums, grinding, edge quality, and inspection</span>
    </Fragment>

    <Fragment slot="subtitle">
      CERAMIC CNC helps evaluate advanced ceramic parts by reviewing material behavior, feature feasibility, grinding
      allowance, surface finish, edge-break control, and acceptance evidence before quotation.
    </Fragment>
  </Hero>

  <Stats
    title="Review areas"
    stats={[
      { title: 'Ceramic material families', amount: '6+' },
      { title: 'Application use cases', amount: '15' },
      { title: 'Precision routes', amount: 'CNC / grind / lap' },
      { title: 'Evidence options', amount: 'CMM / optical / Ra' },
    ]}
  />

  <Features3
    id="process"
    title="Core capabilities"
    subtitle="Capability is feature-specific. The same ceramic grade can quote very differently depending on which faces must be finished and measured."
    columns={3}
    isBeforeContent={true}
    items={ceramicCapabilities}
  />

  <SplitShowcase
    id="inspection"
    title="Capability review modules"
    subtitle="The quote path is clearer when process fit, finishing scope, and inspection evidence are stated early."
    tagline="Engineering review"
    items={capabilityShowcases}
    classes={{ container: sectionContainerClass }}
  />

  <Features2
    title="How we review the quote"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'Manufacturability review',
        description:
          'We review feature geometry, material grade, datum strategy, edge risk, grinding access, and possible inspection paths.',
        icon: 'tabler:messages',
      },
      {
        title: 'Quotation support',
        description:
          'Quotation support is based on drawings, quantity, route assumptions, surface finish, tolerance map, and required evidence.',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>
