---
import { Icon } from 'astro-icon/components';

import { UI } from 'astrowind:config';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
  iconName?: string;
}

const {
  label = 'Toggle between Dark and Light mode',
  class:
    className = 'inline-flex items-center rounded-md p-2.5 text-sm text-muted transition hover:bg-slate-900/[0.035] hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary dark:text-gray-400 dark:hover:bg-white/[0.055] dark:focus:ring-secondary',
  iconClass = 'w-6 h-6',
  iconName = 'tabler:sun',
} = Astro.props;
---

{
  !(UI.theme && UI.theme.endsWith(':only')) && (
    <button type="button" class={className} aria-label={label} data-aw-toggle-color-scheme>
      <Icon name={iconName} class={iconClass} />
    </button>
  )
}
