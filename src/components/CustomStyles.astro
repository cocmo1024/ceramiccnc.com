---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(38 78 96);
    --aw-color-secondary: rgb(89 113 122);
    --aw-color-accent: rgb(79 112 108);

    --aw-color-text-heading: rgb(16 19 21);
    --aw-color-text-default: rgb(38 43 45);
    --aw-color-text-muted: rgb(92 99 101 / 88%);
    --aw-color-text-page: rgb(16 19 21);
    --aw-color-bg-page: rgb(248 249 247);

    --aw-color-bg-page-dark: rgb(7 10 12);

    ::selection {
      background-color: rgb(223 234 236);
      color: rgb(16 19 21);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(54 105 126);
    --aw-color-secondary: rgb(153 178 186);
    --aw-color-accent: rgb(143 174 169);

    --aw-color-text-heading: rgb(242 244 243);
    --aw-color-text-default: rgb(226 232 231);
    --aw-color-text-muted: rgb(162 172 174 / 84%);
    --aw-color-text-page: rgb(242 244 243);
    --aw-color-bg-page: rgb(7 10 12);

    ::selection {
      background-color: rgb(36 62 72);
      color: rgb(242 244 243);
    }
  }
</style>
