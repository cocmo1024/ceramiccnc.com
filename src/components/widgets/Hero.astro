---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative md:-mt-[76px] not-prose" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
    <div class="py-9 md:py-20">
      <div class="mx-auto max-w-5xl pb-8 text-center md:pb-16">
        {
          tagline && (
            <p
              class="text-sm font-semibold uppercase tracking-[0.12em] text-secondary dark:text-secondary intersect-once intersect-quarter"
              set:html={tagline}
            />
          )
        }
        {
          title && (
            <h1
              class="mb-5 text-[2.1rem] font-semibold leading-[1.05] tracking-tight text-heading dark:text-gray-100 md:text-5xl lg:text-6xl intersect-once intersect-quarter"
              set:html={title}
            />
          )
        }
        <div class="max-w-3xl mx-auto">
          {
            subtitle && (
              <p
                class="mb-6 text-base leading-7 text-muted dark:text-slate-300 md:text-xl md:leading-8 intersect-once intersect-quarter"
                set:html={subtitle}
              />
            )
          }
          {
            actions && (
              <div class="m-auto flex max-w-xs flex-nowrap flex-col gap-3 sm:max-w-lg sm:flex-row sm:justify-center sm:gap-4 intersect-once intersect-quarter">
                {Array.isArray(actions) ? (
                  actions.map((action) => (
                    <div class="flex w-full sm:w-auto">
                      <Button {...(action || {})} class="w-full sm:mb-0" />
                    </div>
                  ))
                ) : (
                  <Fragment set:html={actions} />
                )}
              </div>
            )
          }
        </div>
        {content && <Fragment set:html={content} />}
      </div>
      <div class="intersect-once intersect-no-queue intersect-quarter">
        {
          image && (
            <div class="relative m-auto max-w-5xl">
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class="mx-auto rounded-md w-full"
                  widths={[400, 768, 1024, 2040]}
                  sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                  loading="eager"
                  width={1024}
                  height={576}
                  {...image}
                />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
