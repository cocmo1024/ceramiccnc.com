---
import { Icon } from 'astro-icon/components';

export interface Props {
  icon?: string;
  title?: string;
  description?: string;
}

const {
  icon = 'tabler:info-square',
  title = await Astro.slots.render('title'),
  description = await Astro.slots.render('description'),
} = Astro.props;
---

<section class="not-prose py-4">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="surface-panel px-5 py-4 text-center text-sm font-medium leading-6 md:px-6">
      <Icon name={icon} class="inline-block h-4 w-4 align-text-bottom text-primary" />
      <span class="font-bold" set:html={title} />
      <Fragment set:html={description} />
    </div>
  </div>
</section>
