---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Timeline from '~/components/ui/Timeline.astro';
import Image from '~/components/common/Image.astro';
import type { Steps as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  items = [],
  image = await Astro.slots.render('image'),
  isReversed = false,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const hasHeader = title || subtitle || tagline;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-5xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  {
    hasHeader && (
      <div class="mb-8 border-l border-slate-300 py-1 pl-5 dark:border-slate-700">
        {tagline && (
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.12em] text-secondary" set:html={tagline} />
        )}
        {title && <h2 class="text-xl font-semibold tracking-tight dark:text-white md:text-2xl" set:html={title} />}
        {subtitle && (
          <p class="mt-1 max-w-3xl text-sm leading-6 text-muted dark:text-slate-300 md:text-base" set:html={subtitle} />
        )}
      </div>
    )
  }

  <div class={image ? 'grid gap-10 md:grid-cols-2 md:gap-16' : 'w-full'}>
    <div class:list={['self-center', { 'md:order-2': image && isReversed }, { 'w-full': !image }]}>
      <Timeline items={items} classes={classes?.items as Record<string, never>} />
    </div>
    {
      image && (
        <div class:list={['self-center', { 'md:order-1': isReversed }]}>
          {typeof image === 'string' ? (
            <Fragment set:html={image} />
          ) : (
            <Image
              class="media-frame mx-auto w-full"
              widths={[400, 768]}
              sizes="(max-width: 768px) 100vw, 432px"
              width={500}
              height={500}
              layout="responsive"
              src={image?.src}
              alt={image?.alt || ''}
            />
          )}
        </div>
      )
    }
  </div>
</WidgetWrapper>
