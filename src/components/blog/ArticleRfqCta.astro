---
import { Icon } from 'astro-icon/components';
import { rfqEmail, rfqEmailHref } from '~/data/ceramic';

const rfqLinks = [
  {
    title: 'RFQ checklist',
    href: '/posts/rfq-preparation/custom-ceramic-cnc-machining-rfq-checklist/',
  },
  {
    title: 'Material selection',
    href: '/posts/materials-grade-selection/ceramic-material-selection-cnc-machining/',
  },
  {
    title: 'Tolerance map',
    href: '/posts/tolerances-gdt/ceramic-tolerance-capability-map-by-feature-process/',
  },
  {
    title: 'Surface finish guide',
    href: '/posts/surface-finish-functional/ceramic-ssd-surface-finish-specify-control-price/',
  },
];
---

<aside class="not-prose mx-auto mt-12 max-w-5xl px-0">
  <div class="surface-panel overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[1.35fr_0.65fr]">
      <div class="p-5 sm:p-6 lg:p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary">RFQ-ready next step</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
          Turn this ceramic part requirement into a reviewable quote package
        </h2>
        <p class="mt-3 text-sm leading-6 text-muted dark:text-slate-400">
          Send the drawing, STEP/CAD, ceramic material or service environment, quantity, target timing, functional
          surfaces, tolerance priorities, surface finish, cleaning, packaging, and inspection requirements. Feasibility,
          price, lead time, and acceptance scope are confirmed after review.
        </p>

        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a
            href="/rfq/"
            class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/40 dark:bg-secondary dark:text-slate-950 dark:hover:bg-secondary/90"
          >
            Prepare an RFQ
            <Icon name="tabler:arrow-right" class="ml-2 h-4 w-4" />
          </a>
          <a
            href={rfqEmailHref}
            class="inline-flex items-center justify-center rounded-md border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-900 transition hover:border-primary hover:text-primary dark:border-slate-700 dark:text-slate-100 dark:hover:border-secondary dark:hover:text-secondary"
          >
            Email {rfqEmail}
          </a>
        </div>
      </div>

      <div class="border-t border-slate-200/80 p-5 sm:p-6 lg:border-l lg:border-t-0 lg:p-7 dark:border-slate-800">
        <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700 dark:text-slate-300">
          Supporting guides
        </h3>
        <ul class="mt-4 space-y-3">
          {
            rfqLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-flex items-center text-sm font-medium text-primary underline-offset-4 hover:underline dark:text-secondary"
                >
                  <Icon name="tabler:chevron-right" class="mr-2 h-4 w-4" />
                  {link.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</aside>
